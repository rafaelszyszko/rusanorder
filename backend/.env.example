# ─────────────────────────────────────────────────────────
# RusanOrder Backend — Environment Variables
# Copie este arquivo para `.env` e preencha com seus valores.
# `.env` está no .gitignore — NUNCA comite valores reais.
# ─────────────────────────────────────────────────────────

# ── Banco de dados (MySQL / TiDB Serverless / Aiven / etc.) ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=rusanorder
# DB_SSL=true em providers gerenciados (TiDB, PlanetScale, Aiven).
# Mantenha false ou ausente em MySQL local via Docker.
DB_SSL=false

# ── Autenticação ──
# Gere com:  openssl rand -base64 32
JWT_SECRET=changeme-please-generate-a-strong-secret-min-32-chars
JWT_EXPIRES_IN=1d

# ── CORS ──
# Em produção: URL exata do frontend (ex.: https://rusanorder.vercel.app).
# Aceita múltiplas origens separadas por vírgula.
# Vazio = libera tudo (apenas dev).
CORS_ORIGIN=http://localhost:5173

# ── Servidor ──
PORT=3000

# ── Integração de IA (importação de PDFs) ──
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
